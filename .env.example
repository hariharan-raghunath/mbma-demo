# ============================================================
# MBMA Demo — Environment Variables
# 1. Copy this file to .env.local
# 2. Fill in the values below
# 3. Run: node scripts/get-refresh-token.mjs  (adds GOOGLE_REFRESH_TOKEN)
# ============================================================

# ── Google OAuth ─────────────────────────────────────────────
# console.cloud.google.com > Credentials > OAuth 2.0 Client ID
# Authorized redirect URIs:
#   http://localhost:4242/oauth/callback
#   http://localhost:3000/api/auth/callback/google
#   https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── NextAuth ──────────────────────────────────────────────────
# Generate: openssl rand -base64 32   (or any random 32+ char string)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Google Refresh Token ──────────────────────────────────────
# Run: node scripts/get-refresh-token.mjs
# Sign in as the company Google account whose Drive will store everything.
GOOGLE_REFRESH_TOKEN=

# ── Google Drive Root Folder ──────────────────────────────────
# The single root folder where all teacher workspaces will be created.
# URL: drive.google.com/drive/folders/THIS_PART
# The app auto-creates this structure inside it:
#   <Root>/<School>/<Teacher>/Recordings/
#   <Root>/<School>/<Teacher>/Tracking Sheet/<Teacher>'s sheet
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ── Staff Access Control ──────────────────────────────────────
# Comma-separated emails. Prefix with admin: for admin role.
# Example: admin:principal@mbma.com,teacher1@gmail.com
ALLOWED_EMAILS=
